{
  "name": "@tellegen/engine",
  "version": "0.1.1",
  "description": "Browser engine package for tellegen case parsing, solving, studies, previews, and sensitivities.",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eigenergy/tellegen.git",
    "directory": "packages/engine"
  },
  "bugs": {
    "url": "https://github.com/eigenergy/tellegen/issues"
  },
  "homepage": "https://eigenergy.github.io/tellegen/",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./contracts": {
      "types": "./dist/generated/contracts.d.ts",
      "default": "./dist/generated/contracts.js"
    }
  },
  "scripts": {
    "contracts": "node scripts/generate-contracts.mjs",
    "contracts:check": "node scripts/generate-contracts.mjs --check",
    "build": "npm run contracts:check && tsc -p tsconfig.json && node scripts/copy-wasm-assets.mjs",
    "wasm": "wasm-pack build ../../crates/tellegen-wasm --target web --out-dir ../../packages/engine/src/wasm-pkg --out-name tellegen -- --features conic",
    "check": "npm run contracts:check && tsc -p tsconfig.json --noEmit",
    "test:import": "node scripts/import-smoke.mjs",
    "pack:dry-run": "npm pack --dry-run"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
