# Standalone example for a shared Caddy edge proxy. When another stack owns
# ports 80 and 443, keep the app container on an external `edge` network and
# route to `tellegen:8000`.

(secure_headers) {
	header {
		Referrer-Policy strict-origin-when-cross-origin
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		-Server
	}
}

tellegen.example.org {
	encode zstd gzip
	import secure_headers

	rate_limit {
		zone tellegen_solve {
			match {
				path /api/cases/*/solve
			}
			key {remote_host}
			window 10s
			events 5
		}
		zone tellegen_sensitivity {
			match {
				path /api/cases/*/sensitivity/*
			}
			key {remote_host}
			window 10s
			events 25
		}
		zone tellegen_api {
			match {
				path /api/*
			}
			key {remote_host}
			window 10s
			events 100
		}
	}

	reverse_proxy tellegen:8000
}
