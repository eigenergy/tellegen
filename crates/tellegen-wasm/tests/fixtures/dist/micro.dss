! A three-bus three-phase feeder for the multiconductor viewing path: a source
! circuit, a line to a load bus, and a step-down transformer to a secondary bus
! with its own load. No Buscoords, so the frontend lays the graph out
! synthetically.
Clear
Set DefaultBaseFrequency=60

New Circuit.micro basekv=12.47 pu=1.0 phases=3 bus1=sourcebus MVAsc3=2000 MVAsc1=2100

New Line.feeder bus1=sourcebus bus2=loadbus phases=3 length=1

New Transformer.t1 phases=3 windings=2 buses=(loadbus, secondary) conns=(wye, wye) kvs=(12.47, 0.48) kvas=(500, 500) xhl=5.75 %Rs=(0.5, 0.5)

New Load.l1 bus1=loadbus phases=3 conn=wye kv=12.47 kw=500 pf=0.95 model=1 vminpu=0.8 vmaxpu=1.2
New Load.l2 bus1=secondary phases=3 conn=wye kv=0.48 kw=120 pf=0.9 model=1 vminpu=0.8 vmaxpu=1.2

Set VoltageBases=[12.47, 0.48]
Calcvoltagebases
Solve
