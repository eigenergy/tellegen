{
	"name": "tellegen-frontend",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"smoke:build": "node scripts/smoke-build.mjs",
		"wasm": "npm run wasm:core && npm run wasm:sens",
		"wasm:core": "RUSTFLAGS=\"-C target-feature=-simd128,-relaxed-simd\" wasm-pack build ../../crates/tellegen-wasm --target web --out-dir ../../apps/web/src/lib/wasm-pkg --out-name tellegen -- --no-default-features",
		"wasm:sens": "wasm-pack build ../../crates/tellegen-wasm --target web --out-dir ../../apps/web/src/lib/wasm-sens-pkg --out-name tellegen_sens -- --features conic",
		"preview": "vite preview",
		"prepare": "svelte-kit sync",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"format": "prettier --write .",
		"lint": "prettier --check ."
	},
	"dependencies": {
		"@deck.gl/core": "^9.1.0",
		"@deck.gl/layers": "^9.1.0",
		"@deck.gl/mapbox": "^9.1.0",
		"@fontsource-variable/bricolage-grotesque": "^5.1.0",
		"@fontsource/ibm-plex-mono": "^5.2.7",
		"maplibre-gl": "^5.0.0"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.8",
		"@sveltejs/kit": "^2.20.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^3.5.2",
		"svelte": "^5.30.0",
		"svelte-check": "^4.1.0",
		"typescript": "^5.7.0",
		"vite": "^6.3.0"
	}
}
