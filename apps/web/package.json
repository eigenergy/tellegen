{
	"name": "tellegen-frontend",
	"version": "0.1.1",
	"private": true,
	"description": "SvelteKit hosted demo for tellegen power system maps.",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "svelte-kit sync && vite build",
		"engine:build": "npm --prefix ../.. run build:engine",
		"smoke:build": "node scripts/smoke-build.mjs",
		"test:browser": "playwright test",
		"wasm": "npm --prefix ../.. run wasm",
		"preview": "vite preview",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"format": "prettier --write .",
		"lint": "prettier --check ."
	},
	"dependencies": {
		"@tellegen/svelte": "file:../../packages/svelte"
	},
	"devDependencies": {
		"@playwright/test": "^1.56.1",
		"@fontsource-variable/bricolage-grotesque": "^5.1.0",
		"@fontsource/ibm-plex-mono": "^5.2.7",
		"@sveltejs/adapter-static": "^3.0.8",
		"@sveltejs/kit": "^2.20.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^3.5.2",
		"svelte": "^5.30.0",
		"svelte-check": "^4.1.0",
		"typescript": "^5.7.0",
		"vite": "^6.3.0"
	}
}
