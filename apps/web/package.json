{
	"name": "tellegen-frontend",
	"version": "0.1.0",
	"description": "Reactive Svelte frontend package for tellegen power system maps.",
	"license": "MIT",
	"type": "module",
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"src/app.css"
	],
	"sideEffects": [
		"**/*.css"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./map": {
			"types": "./dist/map.d.ts",
			"svelte": "./dist/map.js",
			"default": "./dist/map.js"
		},
		"./components": {
			"types": "./dist/components.d.ts",
			"svelte": "./dist/components.js",
			"default": "./dist/components.js"
		},
		"./types": {
			"types": "./dist/types.d.ts",
			"default": "./dist/types.js"
		},
		"./styles.css": "./src/app.css"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "npm run package && vite build",
		"engine:build": "npm --prefix ../../packages/engine run build",
		"package": "svelte-kit sync && svelte-package --tsconfig ./tsconfig.json",
		"smoke:build": "node scripts/smoke-build.mjs",
		"test:browser": "playwright test",
		"wasm": "npm --prefix ../../packages/engine run wasm",
		"preview": "vite preview",
		"prepare": "svelte-kit sync",
		"prepack": "npm run package",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"format": "prettier --write .",
		"lint": "prettier --check ."
	},
	"peerDependencies": {
		"@deck.gl/core": "^9.1.0",
		"@deck.gl/layers": "^9.1.0",
		"@deck.gl/mapbox": "^9.1.0",
		"maplibre-gl": "^5.0.0",
		"svelte": "^5.30.0"
	},
	"dependencies": {
		"@tellegen/engine": "file:../../packages/engine"
	},
	"devDependencies": {
		"@playwright/test": "^1.56.1",
		"@deck.gl/core": "^9.1.0",
		"@deck.gl/layers": "^9.1.0",
		"@deck.gl/mapbox": "^9.1.0",
		"@fontsource-variable/bricolage-grotesque": "^5.1.0",
		"@fontsource/ibm-plex-mono": "^5.2.7",
		"@sveltejs/adapter-static": "^3.0.8",
		"@sveltejs/kit": "^2.20.0",
		"@sveltejs/package": "^2.5.8",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^3.5.2",
		"maplibre-gl": "^5.0.0",
		"svelte": "^5.30.0",
		"svelte-check": "^4.1.0",
		"typescript": "^5.7.0",
		"vite": "^6.3.0"
	}
}
